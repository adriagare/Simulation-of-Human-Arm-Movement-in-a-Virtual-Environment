# ============================================================
#  Unity (unityproject/)
# ============================================================

# Auto-generated build / cache folders
unityproject/[Ll]ibrary/
unityproject/[Tt]emp/
unityproject/[Oo]bj/
unityproject/[Bb]uild/
unityproject/[Bb]uilds/
unityproject/[Ll]ogs/
unityproject/[Uu]ser[Ss]ettings/
unityproject/[Mm]emoryCaptures/
unityproject/[Rr]ecordings/

# Old / superseded log folder
unityproject/LogData/

# Decorative assets not used by the build
unityproject/deco/

# Auto-generated Visual Studio / Rider files
unityproject/*.csproj
unityproject/*.sln
unityproject/*.slnx
unityproject/*.suo
unityproject/*.user
unityproject/*.userprefs
unityproject/*.unityproj
unityproject/*.vsconfig
unityproject/*.pidb
unityproject/*.booproj
unityproject/*.svd
unityproject/.vs/
unityproject/ExportedObj/
unityproject/.consulo/
unityproject/*.tmp
unityproject/*.apk
unityproject/*.aab
unityproject/*.unitypackage
unityproject/*.app

# Unity crash reports
unityproject/sysinfo.txt
unityproject/crashlytics-build.properties

# Asset meta files for ignored folders shouldn't leak
unityproject/Assets/AssetStoreTools*

