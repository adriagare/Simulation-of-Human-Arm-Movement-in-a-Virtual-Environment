# ============================================================
#  TFG - Simulation of Human Arm Movement in a Virtual Environment
#  .gitignore
# ============================================================
#  Estrategia: per defecte excloem-ho TOT i tornem a incloure
#  explicitament les carpetes/fitxers que volem versionar.
# ============================================================

# --- Per defecte, ignorem tot el contingut del repositori ---
/*

# --- Permetem fitxers de top-level imprescindibles ---
!/.gitignore
!/README.md
!/LICENSE
/CODI.md

# ============================================================
#  Carpetes que volem versionar SENCERES
# ============================================================
!/analisi
!/data_analysis
!/PythonClient

# --- analisi/ : tot, pero sense caches Python ---
analisi/__pycache__/
analisi/**/__pycache__/
analisi/*.pyc

# --- data_analysis/ : tot ---

# --- PythonClient/ : tot, pero sense caches Python ---
PythonClient/__pycache__/
PythonClient/**/__pycache__/
PythonClient/*.pyc

# ============================================================
#  exp/ - nomes la carpeta example_data anonimitzada
# ============================================================
!/exp
exp/*
!exp/example_data
!exp/example_data/**

# ============================================================
#  Thesis/ - nomes els dos PDFs finals
# ============================================================
!/Thesis
Thesis/*
!Thesis/CAT_Thesis.pdf
!Thesis/CAT_Manual_Participant.pdf

# ============================================================
#  unityproject/ - nomes el codi font i la configuracio
#                  (Library/, Logs/, builds, IDE files exclosos)
# ============================================================
!/unityproject
unityproject/*

# Carpetes imprescindibles per reproduir el projecte
!unityproject/Assets
!unityproject/Assets/**
!unityproject/Packages
!unityproject/Packages/**
!unityproject/ProjectSettings
!unityproject/ProjectSettings/**

# Dins Assets/ excloem fitxers que no han d'anar al repo
unityproject/Assets/**/*.meta.bak
unityproject/Assets/AssetStoreTools*

# ============================================================
#  Sistema operatiu i editors (s'ignoren sempre)
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~
*.tmp

# ============================================================
#  Python (en qualsevol punt del projecte)
# ============================================================
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# ============================================================
#  LaTeX auxiliars (no s'han de versionar)
# ============================================================
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
texput.log
